{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "PowerShell(headroom --version)",
      "PowerShell(Get-ChildItem \"$env:USERPROFILE\" -Filter \"conda.exe\" -Recurse -Depth 4 2>$null | Select-Object FullName -First 3)",
      "mcp__headroom__headroom_compress",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(*)",
      "PowerShell(*)",
      "Edit(presentation/**)",
      "Write(presentation/**)",
      "Edit(images_and_plots/**)",
      "Write(images_and_plots/**)",
      "WebSearch",
