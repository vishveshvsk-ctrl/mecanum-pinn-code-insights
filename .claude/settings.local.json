      "Write(*.sh)",
      "Write(*.ps1)",
      "Edit(*.sh)",
      "Edit(*.ps1)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/vishv/OneDrive/Desktop/Vishvesh_Data/VNIT/mecanum_pinn_head/code_insights/.claude/check_project_scope.py"
          }
        ]
      }
